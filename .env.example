ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha
SQLITE_PATH=data/portal11run.sqlite
UPLOAD_DIR=data/uploads
VIRTUAL_CIRCUIT_PRIVATE_UPLOAD_DIR=data/virtual-circuit-private
NEXT_PUBLIC_SITE_URL=http://localhost:80

# Gere com um segredo aleatório de pelo menos 32 caracteres. Não reutilize a chave da Stripe.
VIRTUAL_CIRCUIT_DATA_KEY=substitua-por-um-segredo-aleatorio-longo

# Fase 2 (opcional). Sem estas variáveis, toda inscrição segue para revisão humana.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://seu-dominio/api/circuito-virtual/strava/callback
VIRTUAL_CIRCUIT_AI_PROVIDER=

# Use uma chave restrita da Stripe com acesso apenas a Checkout Sessions.
STRIPE_SECRET_KEY=rk_live_substitua_por_uma_chave_restrita

# Gerado ao cadastrar https://seu-dominio/api/stripe/webhook no Stripe Workbench.
STRIPE_WEBHOOK_SECRET=whsec_substitua_pelo_segredo_do_webhook
